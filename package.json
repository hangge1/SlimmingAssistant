{
  "name": "slimming-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-bt.mjs",
    "start:bt": "node scripts/start-bt.mjs",
    "start:bt:3000": "node scripts/start-bt.mjs --port 3000",
    "start:bt:3001": "node scripts/start-bt.mjs --port 3001",
    "start:bt:3002": "node scripts/start-bt.mjs --port 3002",
    "prepare:bt": "node scripts/boot-bt.mjs --prepare-only",
    "release": "npm run build && node scripts/create-release-package.mjs",
    "release:with-data": "npm run build && node scripts/create-release-package.mjs --with-data",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate-db.mjs",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@types/nodemailer": "^8.0.1",
    "better-sqlite3": "12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.532.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.1",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
  }
}
