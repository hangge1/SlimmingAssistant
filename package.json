{
  "name": "reset-life",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev-go-astro.mjs",
    "build": "npm run web:build && npm run api:build",
    "start": "node scripts/start-go-astro.mjs",
    "start:bt": "node scripts/start-go-astro.mjs --port 3000",
    "start:bt:3000": "node scripts/start-go-astro.mjs --port 3000",
    "start:bt:3001": "node scripts/start-go-astro.mjs --port 3001",
    "start:bt:3002": "node scripts/start-go-astro.mjs --port 3002",
    "release": "node scripts/create-go-astro-release-package.mjs",
    "release:with-data": "node scripts/create-go-astro-release-package.mjs",
    "release:go-astro": "node scripts/create-go-astro-release-package.mjs",
    "deploy:cloud": "node scripts/deploy-cloud.mjs",
    "deploy:cloud:skip-release": "node scripts/deploy-cloud.mjs --skip-release",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:check": "npm --prefix web run check",
    "api:dev": "cd server && go run ./cmd/api",
    "api:build": "cd server && go build -trimpath -o ../dist/local/resetlife-api ./cmd/api",
    "api:test": "cd server && go test ./...",
    "lint": "eslint scripts/create-go-astro-release-package.mjs scripts/deploy-cloud.mjs scripts/dev-go-astro.mjs scripts/start-go-astro.mjs tests/go-astro-default.test.mjs web/src/**/*.ts",
    "typecheck": "npm run web:check",
    "test": "node --test tests/go-astro-default.test.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run api:test",
    "check:all": "npm run check && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
