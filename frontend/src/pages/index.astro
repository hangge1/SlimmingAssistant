---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { disorderStates, resetFlow, resetSystems } from "@/data/site";
---

<SiteLayout title="复位 | 重建人生系统" description="当你感到失序时，复位会陪你一步步重新看见自己、理解问题并开始行动。">
  <SiteHeader />
  <main>
    <section class="reset-hero">
      <div class="reset-hero-grid">
        <div class="reset-hero-copy">
          <p class="eyebrow">我们先把生活重新接上</p>
          <h1>复位</h1>
          <p class="hero-subtitle">重建人生系统</p>
          <p class="hero-copy">
            如果你现在觉得自己乱了、卡住了、动不起来，我们先不谈大道理。我们一步步看见你自己，整理你面对的问题，再做一个小到能开始的动作。
          </p>
          <div class="actions">
            <a class="button button-primary" href="/state/">开始状态识别</a>
            <a class="button button-secondary" href="#flow">看看完整路径</a>
          </div>
        </div>
        <div class="system-board" aria-label="复位闭环">
          <span>状态识别</span>
          <span>复位路径</span>
          <span>选择修复方向</span>
          <span>记录复位过程</span>
          <span>看见他人的复位历程</span>
        </div>
      </div>
    </section>

    <section class="section compact-section" aria-labelledby="state-title">
      <div class="section-heading">
        <p>Diagnosis</p>
        <h2 id="state-title">状态识别</h2>
        <span>你不用解释清楚为什么。先从选项里找一个最像你现在的状态。</span>
      </div>
      <div class="state-grid">
        {disorderStates.map((state) => (
          <a class="state-chip" href={`/state/?state=${encodeURIComponent(state.label)}`}>{state.label}</a>
        ))}
      </div>
    </section>

    <section id="flow" class="section section-muted">
      <div class="section-heading">
        <p>Reset Path</p>
        <h2>我们按这个顺序来</h2>
        <span>先识别状态，再给复位路径。心理、认知、行为，是路径里的三条修复方向。</span>
      </div>
      <div class="flow-grid">
        {resetFlow.map((item, index) => (
          <a class="flow-card" href={item.href}>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{item.title}</strong>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section id="directions" class="section">
      <div class="section-heading">
        <p>Treatment Directions</p>
        <h2>状态识别之后，我们再进入三大修复方向</h2>
        <span>你不用自己判断该去哪一页。状态对话结束后，我会先帮你整理一个优先方向。</span>
      </div>
      <div class="card-grid">
        {resetSystems.map((system) => (
          <a class="card system-card" href={system.href}>
            <span class="card-index">{system.index}</span>
            <h3>{system.title}</h3>
            <strong>{system.role}</strong>
            <strong>{system.question}</strong>
            <p>{system.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section section-muted">
      <div class="section-heading">
        <p>Next</p>
        <h2>现在先不用选修复方向</h2>
        <span>你先做一次状态识别。等我们看清楚状态，再决定今天从心理、认知，还是行为开始。</span>
      </div>
      <a class="button button-primary" href="/state/">进入状态识别</a>
    </section>
  </main>
  <SiteFooter />
</SiteLayout>
