---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { resetSystems } from "@/data/site";
---

<SiteLayout title="复位报告 | 复位" description="自我定位之后，我们把你的秩序结构整理成一份可行动的复位报告。">
  <SiteHeader />
  <main class="tool-page">
    <section class="tool-hero">
      <p class="eyebrow">复位报告</p>
      <h1>你的复位报告</h1>
      <p>自我定位之后，我们先不急着做很多事。我们只看清：你现在主要乱在哪里，今天先从哪条自我修复方向开始。</p>
    </section>

    <section class="path-layout">
      <article class="tool-panel path-summary" id="path-summary" aria-live="polite">
        <div class="panel-heading">
          <h2>我先帮你把刚才的自我定位整理一下</h2>
          <p>如果这里还没有内容，你可以先做一次自我定位。</p>
        </div>
        <div class="result-box">
          还没有可用的复位报告。我们先从自我定位开始。
        </div>
        <div class="actions">
          <a class="button button-primary" href="/state/">开始自我定位</a>
        </div>
      </article>

      <aside class="tool-panel">
        <div class="panel-heading">
          <h2>今天只需要一个优先方向</h2>
          <p>你不用同时处理心理、认知和行动。先按报告里最明显的一条路走，做完再回来复盘。</p>
        </div>
        <div class="acceptance-list">
          <span>如果你很难受，先走心理复位。</span>
          <span>如果你很混乱，先走认知复位。</span>
          <span>如果你动不起来，先走行动复位。</span>
        </div>
      </aside>
    </section>

    <section id="directions" class="section path-directions">
      <div class="section-heading">
        <p>修复方向</p>
        <h2>自我修复的三条方向</h2>
        <span>这三条路不是内容分类，而是你完成自我定位之后可能进入的修复路径。</span>
      </div>
      <div class="card-grid">
        {resetSystems.map((system) => (
          <a class="card system-card" href={system.href}>
            <span class="card-index">{system.index}</span>
            <h3>{system.title}</h3>
            <strong>{system.role}</strong>
            <p>{system.description}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />
</SiteLayout>

<script is:inline>
  const pathKey = "resetlife:latest-path";
  const summary = document.querySelector("#path-summary");

  function escapeHtml(value) {
    return String(value).replace(/[&<>"']/g, (char) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#039;",
    })[char]);
  }

  function readPlan() {
    try {
      return JSON.parse(localStorage.getItem(pathKey) || "null");
    } catch {
      return null;
    }
  }

  function renderBars(scores) {
    if (!Array.isArray(scores) || !scores.length) return "";
    return `
      <div class="order-bars">
        ${scores
          .map(
            (item) => `
              <div class="order-bar">
                <span>${escapeHtml(item.title || "")}</span>
                <strong>${escapeHtml(item.percent ?? 0)}%</strong>
                <i style="--value: ${escapeHtml(item.percent ?? 0)}%"></i>
              </div>
            `,
          )
          .join("")}
      </div>
    `;
  }

  const plan = readPlan();
  if (plan) {
    summary.innerHTML = `
      <div class="panel-heading">
        <h2>这是你这次的复位报告</h2>
        <p>先按报告里的优先方向走，不需要同时解决全部问题。</p>
      </div>
      <div class="result-box">
        <strong>${escapeHtml(plan.conclusion?.title || plan.direction?.title || "心理复位")}</strong>
        ${renderBars(plan.scores || [])}
        <p>${escapeHtml(plan.conclusion?.mechanism || "我们先把当前状态看清楚，再走下一步。")}</p>
        <p>${escapeHtml(plan.direction?.reason || "我们先从一个能开始的小动作走起。")}</p>
        <p>一开始你更像：${escapeHtml(plan.initialEntry?.label || "暂未选择")}</p>
        <p>你刚才选到的明显状态：${escapeHtml((plan.states || []).slice(0, 8).join(" / ") || "暂未选择")}</p>
        ${plan.note ? `<p>你补充说：${escapeHtml(plan.note)}</p>` : ""}
      </div>
      <div class="actions">
        <a class="button button-primary" href="${escapeHtml(plan.direction?.href || "/psychology/")}">进入${escapeHtml(plan.direction?.title || "心理复位")}</a>
        <a class="button button-secondary" href="/review/">做完后回来复盘</a>
      </div>
    `;
  }
</script>


