---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { disorderStates, lifeAreas, resetStages } from "@/data/site";
---

<SiteLayout title="状态识别 | 复位" description="我们像状态对话一样，一轮一轮看见你现在卡在哪里。">
  <SiteHeader />
  <main class="tool-page">
    <section class="tool-hero">
      <p class="eyebrow">状态识别</p>
      <h1>状态识别</h1>
      <p>我们不一次性问完所有问题。你跟着卡片一轮一轮选，哪里说不准，就用自己的话补一句。</p>
    </section>

    <section class="tool-grid dialogue-layout">
      <form class="tool-panel dialogue-panel" id="state-form">
        <div class="dialogue-progress" aria-label="状态识别进度">
          <span class="progress-dot is-active" data-progress-dot></span>
          <span class="progress-dot" data-progress-dot></span>
          <span class="progress-dot" data-progress-dot></span>
          <span class="progress-dot" data-progress-dot></span>
          <span class="progress-dot" data-progress-dot></span>
          <span class="progress-dot" data-progress-dot></span>
        </div>

        <section class="dialogue-card is-active" data-dialogue-card>
          <span class="dialogue-step">第 1 轮</span>
          <div class="doctor-message">
            <strong>我们先慢一点。</strong>
            <p>你不需要马上解释为什么会这样。我们先像面对面对话一样，只看你现在最明显的感受。</p>
          </div>
          <div class="dialogue-actions">
            <button class="button button-primary" type="button" data-next>开始</button>
          </div>
        </section>

        <section class="dialogue-card" data-dialogue-card hidden>
          <span class="dialogue-step">第 2 轮</span>
          <div class="panel-heading">
            <h2>你现在最像哪种失序状态？</h2>
            <p>可以多选。先选最刺眼、最影响你的那个；如果选项不准，你可以自己写。</p>
          </div>
          <div class="choice-grid">
            {disorderStates.map((state) => (
              <label class="choice-card">
                <input type="checkbox" name="state" value={state.label} data-suggestion={state.suggestion} />
                <span>{state.label}</span>
              </label>
            ))}
          </div>
          <label class="custom-field">
            如果都不像，你可以自己写一个状态
            <input name="customState" placeholder="例如：我只是觉得整个人很散，什么都抓不住" />
          </label>
          <p class="form-message" data-step-error></p>
          <div class="dialogue-actions">
            <button class="button button-secondary" type="button" data-prev>上一轮</button>
            <button class="button button-primary" type="button" data-next>继续</button>
          </div>
        </section>

        <section class="dialogue-card" data-dialogue-card hidden>
          <span class="dialogue-step">第 3 轮</span>
          <div class="panel-heading">
            <h2>现在最受影响的是哪一块？</h2>
            <p>我们先找到失序最明显的位置，不急着处理全部生活。</p>
          </div>
          <div class="choice-grid">
            {lifeAreas.map((area) => (
              <label class="choice-card">
                <input type="radio" name="lifeArea" value={area} />
                <span>{area}</span>
              </label>
            ))}
          </div>
          <label class="custom-field">
            也可以写你自己的说法
            <input name="customLifeArea" placeholder="例如：家里一团乱，整个人也跟着乱" />
          </label>
          <p class="form-message" data-step-error></p>
          <div class="dialogue-actions">
            <button class="button button-secondary" type="button" data-prev>上一轮</button>
            <button class="button button-primary" type="button" data-next>继续</button>
          </div>
        </section>

        <section class="dialogue-card" data-dialogue-card hidden>
          <span class="dialogue-step">第 4 轮</span>
          <div class="panel-heading">
            <h2>你觉得自己现在停在哪一步？</h2>
            <p>这不是考试。只是帮我们判断：今天应该先看见、先理解，还是先做一个小动作。</p>
          </div>
          <div class="choice-grid">
            {resetStages.map((stage) => (
              <label class="choice-card">
                <input type="radio" name="stage" value={stage} />
                <span>{stage}</span>
              </label>
            ))}
          </div>
          <label class="custom-field">
            如果这些阶段都不准，你可以自己描述
            <input name="customStage" placeholder="例如：我像是还没准备好面对问题" />
          </label>
          <p class="form-message" data-step-error></p>
          <div class="dialogue-actions">
            <button class="button button-secondary" type="button" data-prev>上一轮</button>
            <button class="button button-primary" type="button" data-next>继续</button>
          </div>
        </section>

        <section class="dialogue-card" data-dialogue-card hidden>
          <span class="dialogue-step">第 5 轮</span>
          <div class="panel-heading">
            <h2>还有没有一句话，是你想补给自己的？</h2>
            <p>可以留空。也可以只写一句很短的话，像是“我现在真的很累”。</p>
          </div>
          <label>
            你的补充
            <textarea name="note" rows="4" placeholder="说不清也没关系。你只想补一句的话，可以写在这里。"></textarea>
          </label>
          <div class="dialogue-actions">
            <button class="button button-secondary" type="button" data-prev>上一轮</button>
            <button class="button button-primary" type="button" data-next>帮我整理</button>
          </div>
        </section>

        <section class="dialogue-card" data-dialogue-card hidden>
          <span class="dialogue-step">第 6 轮</span>
          <div class="panel-heading">
            <h2>我先帮你整理成今天的一小步</h2>
            <p>你可以先保存下来。之后再回来，你会看到自己是怎么一点点复位的。</p>
          </div>
          <div class="result-box" id="state-result" aria-live="polite"></div>
          <div class="dialogue-actions">
            <button class="button button-secondary" type="button" data-prev>上一轮</button>
            <button class="button button-primary" type="submit">保存这次状态对话</button>
          </div>
        </section>
      </form>

      <aside class="tool-panel result-panel" aria-live="polite">
        <div class="panel-heading">
          <h2>你的状态对话记录</h2>
          <p>我会把这次选择留在你的浏览器里。之后你可以回来看看自己怎么变化。</p>
        </div>
        <div class="saved-list" id="state-list"></div>
      </aside>
    </section>
  </main>
  <SiteFooter />
</SiteLayout>

<script is:inline>
  const storageKey = "resetlife:user-states";
  const pathKey = "resetlife:latest-path";
  const form = document.querySelector("#state-form");
  const result = document.querySelector("#state-result");
  const list = document.querySelector("#state-list");
  const cards = Array.from(document.querySelectorAll("[data-dialogue-card]"));
  const dots = Array.from(document.querySelectorAll("[data-progress-dot]"));
  let currentStep = 0;

  function escapeHtml(value) {
    return String(value).replace(/[&<>"']/g, (char) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#039;",
    })[char]);
  }

  function readItems() {
    try {
      return JSON.parse(localStorage.getItem(storageKey) || "[]");
    } catch {
      return [];
    }
  }

  function writeItems(items) {
    localStorage.setItem(storageKey, JSON.stringify(items.slice(0, 20)));
  }

  function getDiagnosisDraft() {
    const data = new FormData(form);
    const selected = Array.from(form.querySelectorAll('input[name="state"]:checked'));
    const customState = String(data.get("customState") || "").trim();
    const states = [...selected.map((input) => input.value), customState].filter(Boolean);
    return {
      states,
      suggestion:
        selected[0]?.dataset.suggestion ||
        "你已经把自己的状态说出来了。今天先从一个最小动作开始，不急着解释全部原因。",
      lifeArea: String(data.get("customLifeArea") || data.get("lifeArea") || "暂未选择").trim(),
      stage: String(data.get("customStage") || data.get("stage") || "看见自己").trim(),
      note: String(data.get("note") || "").trim(),
    };
  }

  function getRecommendedDirection(draft) {
    const joined = `${draft.states.join(" ")} ${draft.lifeArea} ${draft.stage}`;
    if (/行动力崩塌|长期拖延|身体|生活秩序|重新行动/.test(joined)) {
      return {
        title: "行为重构",
        href: "/action/",
        reason: "你现在最需要的是先恢复一点行动秩序。我们不从大目标开始，只从一个能完成的小动作开始。",
      };
    }
    if (/认知混乱|目标丧失|学习|事业|金钱|理解世界/.test(joined)) {
      return {
        title: "认知重塑",
        href: "/cognition/",
        reason: "你现在更需要先把问题看清楚。我们先抓住一个困惑，再用一个概念帮你整理它。",
      };
    }
    return {
      title: "心理重建",
      href: "/psychology/",
      reason: "你现在更需要先被自己接住。我们先看见情绪、触发和自动想法，不急着马上改变。",
    };
  }

  function renderList() {
    const items = readItems();
    if (!items.length) {
      list.innerHTML = '<p class="empty-note">还没有保存的状态对话记录。</p>';
      return;
    }
    list.innerHTML = items
      .map(
        (item) => `
          <article class="saved-item">
            <span>${escapeHtml(item.date)}</span>
            <strong>${escapeHtml(item.states.join(" / "))}</strong>
            <p>${escapeHtml(item.suggestion)}</p>
          </article>
        `,
      )
      .join("");
  }

  function renderResult() {
    const draft = getDiagnosisDraft();
    const direction = getRecommendedDirection(draft);
    result.innerHTML = `
      <strong>${escapeHtml(draft.states.join(" / "))}</strong>
      <p>${escapeHtml(draft.suggestion)}</p>
      <p>现在最受影响的是：${escapeHtml(draft.lifeArea)}</p>
      <p>我们先按这个阶段来走：${escapeHtml(draft.stage)}</p>
      <p>今天建议先进入：${escapeHtml(direction.title)}</p>
      ${draft.note ? `<p>你补充说：${escapeHtml(draft.note)}</p>` : ""}
    `;
  }

  function setStep(nextStep) {
    currentStep = Math.max(0, Math.min(nextStep, cards.length - 1));
    cards.forEach((card, index) => {
      const active = index === currentStep;
      card.hidden = !active;
      card.classList.toggle("is-active", active);
    });
    dots.forEach((dot, index) => {
      dot.classList.toggle("is-active", index === currentStep);
      dot.classList.toggle("is-complete", index < currentStep);
    });
    if (currentStep === cards.length - 1) renderResult();
  }

  function showStepError(message) {
    const error = cards[currentStep].querySelector("[data-step-error]");
    if (error) error.textContent = message;
  }

  function clearStepError() {
    const error = cards[currentStep].querySelector("[data-step-error]");
    if (error) error.textContent = "";
  }

  function canLeaveCurrentStep() {
    const draft = getDiagnosisDraft();
    if (currentStep === 1 && !draft.states.length) {
      showStepError("先选一个最像你现在的状态，或者写一句自己的状态，我们再继续。");
      return false;
    }
    clearStepError();
    return true;
  }

  function selectFromQuery() {
    const selectedState = new URLSearchParams(window.location.search).get("state");
    if (!selectedState) return;
    const input = form.querySelector(`input[value="${CSS.escape(selectedState)}"]`);
    if (input) input.checked = true;
  }

  form.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    if (target.matches("[data-next]")) {
      if (!canLeaveCurrentStep()) return;
      setStep(currentStep + 1);
    }
    if (target.matches("[data-prev]")) {
      clearStepError();
      setStep(currentStep - 1);
    }
  });

  form.addEventListener("submit", (event) => {
    event.preventDefault();
    const draft = getDiagnosisDraft();
    if (!draft.states.length) {
      setStep(1);
      showStepError("先选一个最像你现在的状态，或者写一句自己的状态，我们再继续。");
      return;
    }
    const item = {
      date: new Date().toLocaleString("zh-CN", { hour12: false }),
      ...draft,
    };
    const direction = getRecommendedDirection(draft);
    writeItems([item, ...readItems()]);
    localStorage.setItem(pathKey, JSON.stringify({ ...item, direction }));
    renderList();
    result.innerHTML += '<p class="record-message">已经保存。我们现在去看你的复位路径。</p>';
    window.location.href = "/path/";
  });

  selectFromQuery();
  renderList();
  setStep(0);
</script>

