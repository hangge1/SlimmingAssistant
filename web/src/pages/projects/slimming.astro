---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout title="跑步瘦身助手 | Hangge Projects" description="跑步瘦身助手项目介绍。">
  <SiteHeader />
  <main class="project-detail">
    <section class="detail-hero">
      <img class="detail-backdrop" src="/projects/slimming-home-preview.png" alt="" aria-hidden="true" />
      <div class="detail-hero-copy">
        <p class="eyebrow">Project · Running & Weight Loss</p>
        <h1>跑步瘦身助手</h1>
        <p>
          一个面向个人使用的健康与跑步管理工具。它把每日记录、目标差距、趋势反馈和提醒机制串成一个低摩擦闭环。
        </p>
        <div class="actions">
          <a class="button button-primary" href="/app/slimming/">进入应用</a>
          <a class="button button-secondary" href="/">返回个人站</a>
        </div>
      </div>
    </section>

    <section class="section section-muted">
      <div class="section-heading">
        <p>Architecture</p>
        <h2>当前架构</h2>
        <span>个人站负责介绍与入口，跑步助手作为独立应用承载登录、记录、数据、历史和设置。</span>
      </div>
      <div class="card-grid">
        <article class="card">
          <span class="card-index">前端</span>
          <h3>Astro + Vue</h3>
          <p>Astro 负责个人站内容，Vue 负责跑步助手交互界面。</p>
        </article>
        <article class="card">
          <span class="card-index">后端</span>
          <h3>Go API</h3>
          <p>后端承接登录、记录、目标、提醒和数据库访问。</p>
        </article>
        <article class="card">
          <span class="card-index">部署</span>
          <h3>宝塔部署</h3>
          <p>Nginx 托管静态文件，/api 反向代理到 Go 服务。</p>
        </article>
      </div>
    </section>
  </main>
  <SiteFooter />
</SiteLayout>
